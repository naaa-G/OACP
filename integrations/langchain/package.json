{
  "name": "@oacp/integration-langchain",
  "version": "1.0.0",
  "description": "LangChain tools adapter for OACP — delegate tasks to agent capabilities",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\""
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0",
    "zod": ">=3.22.0"
  },
  "dependencies": {
    "@oacp/sdk": "workspace:*"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.42",
    "@oacp/server": "workspace:*",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
