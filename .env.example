# OACP Docker Compose environment (copy to `.env` and customize)
#
# Enterprise auth: set OACP_API_KEY — the nginx gateway injects Authorization so the
# Console bundle does NOT need VITE_OACP_API_KEY at build time.
#
# Generate a key: openssl rand -base64 32

# OACP_PUBLISH_PORT=3847
# OACP_API_KEY=
# OACP_MEMORY_BACKEND=sqlite
# OACP_SERVER_LOG_LEVEL=info
#
# Day 53 — MCPLab observability sync (enabled by `pnpm docker:mcplab`)
OACP_IMPORT_FROM_MCPLAB=1
MCPLAB_OBSERVABILITY_EXPORT_URL=http://mcplab-api:8001/internal/observability/export
MCPLAB_TRACE_STATUS_WEBHOOK_URL=http://mcplab-api:8001/internal/observability/trace-status
# MCPLAB_SYNC_SECRET=   # defaults to OACP_API_KEY when unset
