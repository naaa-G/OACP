{
  "name": "@oacp/server",
  "version": "0.1.0",
  "description": "OACP reference HTTP server — remote message ingress and agent lookup",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "oacp-trace": "./dist/bin/trace-view.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/cli.js",
    "prestart": "pnpm run build",
    "trace": "node dist/bin/trace-view.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\""
  },
  "dependencies": {
    "@oacp/core": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/pg": "^8.11.10",
    "vitest": "^2.1.8"
  }
}
