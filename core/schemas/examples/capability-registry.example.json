{
  "agent_id": "agent://summarizer",
  "version": "1.0",
  "declarations": [
    {
      "id": "text.summarize",
      "name": "Text Summarization",
      "description": "Produces a concise summary of arbitrary text input.",
      "version": "1.0.0",
      "tags": ["nlp", "text"],
      "inputSchema": {
        "type": "object",
        "required": ["text"],
        "properties": {
          "text": { "type": "string", "minLength": 1 }
        }
      },
      "outputSchema": {
        "type": "object",
        "required": ["summary"],
        "properties": {
          "summary": { "type": "string" }
        }
      }
    }
  ]
}
